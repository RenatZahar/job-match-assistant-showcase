# Backend runtime
APP_ENV=local
DATABASE_URL=
CORS_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173
BASIC_AUTH_USERS=

# Match provider: the frontend defaults to mock mode, so these can stay empty.
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=low
OPENAI_STORE_RESPONSES=false
OPENAI_DEBUG_RESPONSES=false
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_MAX_OUTPUT_TOKENS=4000

# Optional experimental vacancy-search provider
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_API_BASE=https://api.brightdata.com/datasets/v3
